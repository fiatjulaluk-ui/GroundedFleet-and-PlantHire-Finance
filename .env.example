# Copy this file to .env and fill in your local values.

# PostgreSQL connection used by analysis/db.py when running against a database.
# Example:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/grounded_finance
DATABASE_URL=

DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=1800
LOG_LEVEL=INFO

